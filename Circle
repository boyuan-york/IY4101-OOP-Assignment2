public class Circle extends Shape {
    private double radius;
    public Circle(Coordinates c, double r) { super(0,c); radius = r; }
    public double getArea() { return Math.PI*radius*radius; }
    public double getPerimeter() { return 2*Math.PI*radius; }
    public void scale(int f, boolean s) {
        getCoordinates().scale(f,s);
        radius = s ? radius*f : (f!=0 ? radius/f : radius);
    }
    public String display() {
        return "Circle | "+getCoordinates().display()+" | R:"+radius+" | Area:"+getArea()+" | Circ:"+getPerimeter();
    }
}
